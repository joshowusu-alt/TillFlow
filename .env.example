# TillFlow environment variables
# Copy this file to .env for local development, then replace placeholders with real values.
# Never commit real secrets or production credentials.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local development database (SQLite example).
DATABASE_URL="file:./dev.db"

# Production / Vercel Postgres database (Neon pooled connection for Prisma app traffic).
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct Postgres connection for migrations / schema operations.
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Optional: force Prisma's library engine in local development.
# PRISMA_CLIENT_ENGINE_TYPE="library"

# -----------------------------------------------------------------------------
# App URLs & runtime
# -----------------------------------------------------------------------------
# Next.js usually sets NODE_ENV automatically. Override only if needed.
NODE_ENV="development"

# Canonical app URL used for password reset links and secure-cookie detection.
BASE_URL="http://localhost:6200"

# Public app URL used when generating links in the browser/server actions.
NEXT_PUBLIC_APP_URL="http://localhost:6200"

# Auto-set by Vercel in deployments; keep blank locally unless you need to simulate it.
VERCEL_URL=""

# Local dev port used by scripts/start-local-dev.mjs.
PORT="6200"

# -----------------------------------------------------------------------------
# Auth, cron & protected internal endpoints
# -----------------------------------------------------------------------------
# Shared secret for cron and protected maintenance endpoints.
CRON_SECRET="replace-with-a-long-random-secret"

# One-time seed endpoint protection.
SEED_SECRET="replace-with-a-long-random-seed-token"

# Enable the /api/seed-once route in production-like environments only when intentional.
SEED_ENABLED=""

# Allow Prisma seed.ts to run while NODE_ENV=production.
ALLOW_SEED="false"

# Bearer token required by /api/metrics.
METRICS_TOKEN="replace-with-a-long-random-metrics-token"

# -----------------------------------------------------------------------------
# Redis / rate limiting
# -----------------------------------------------------------------------------
# Optional Upstash Redis credentials. Leave blank to fall back to in-memory throttling.
UPSTASH_REDIS_REST_URL="https://example.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-token"

# -----------------------------------------------------------------------------
# Password reset email delivery
# -----------------------------------------------------------------------------
# Optional Resend API key. Leave blank to disable outbound password reset email delivery.
RESEND_API_KEY="re_placeholder_resend_api_key"

# Optional sender identity for password reset emails.
RESEND_FROM_EMAIL="TillFlow <noreply@example.com>"

# -----------------------------------------------------------------------------
# File storage
# -----------------------------------------------------------------------------
# Optional Vercel Blob token for durable expense attachment uploads.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_placeholder"

# -----------------------------------------------------------------------------
# Meta WhatsApp notifications
# -----------------------------------------------------------------------------
# Set to true to use mock mode locally without real Meta credentials.
META_WHATSAPP_MOCK="true"

# Meta WhatsApp Cloud API access token.
META_WHATSAPP_ACCESS_TOKEN=""

# WhatsApp business phone number ID from Meta.
META_WHATSAPP_PHONE_NUMBER_ID=""

# Meta Graph API version. Defaults to v23.0 in code.
META_WHATSAPP_API_VERSION="v23.0"

# Optional approved template name for outbound notifications.
META_WHATSAPP_TEMPLATE_NAME=""

# Template language code used with META_WHATSAPP_TEMPLATE_NAME.
META_WHATSAPP_TEMPLATE_LANGUAGE_CODE="en_GB"

# Verify token for the Meta webhook challenge flow.
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN="replace-with-meta-webhook-verify-token"

# Meta app secret used to validate webhook signatures.
META_WHATSAPP_APP_SECRET="replace-with-meta-app-secret"

# -----------------------------------------------------------------------------
# MTN MoMo collections
# -----------------------------------------------------------------------------
# Set to true for local testing without live MTN credentials.
MTN_MOMO_COLLECTION_MOCK="true"

# MTN Collections API base URL.
MTN_MOMO_COLLECTION_BASE_URL="https://sandbox.momodeveloper.mtn.com"

# MTN Collections user ID / API user.
MTN_MOMO_COLLECTION_USER_ID=""

# MTN Collections API key for the API user.
MTN_MOMO_COLLECTION_API_KEY=""

# MTN subscription key for the MTN product.
MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=""

# MTN target environment, usually sandbox or production.
MTN_MOMO_COLLECTION_TARGET_ENV="sandbox"

# Public webhook callback URL for MTN collection updates.
MTN_MOMO_COLLECTION_CALLBACK_URL="https://example.com/api/payments/momo/webhook/mtn"

# Shared secret for validating MTN webhook requests.
MTN_MOMO_COLLECTION_WEBHOOK_SECRET="replace-with-mtn-webhook-secret"

# -----------------------------------------------------------------------------
# QZ Tray trusted printing
# -----------------------------------------------------------------------------
# Optional PEM certificate for trusted QZ Tray signing. Use \n for multiline values if needed.
QZ_TRAY_CERTIFICATE=""

# Optional PEM private key matching QZ_TRAY_CERTIFICATE. Use \n for multiline values if needed.
QZ_TRAY_PRIVATE_KEY=""

# -----------------------------------------------------------------------------
# Test / QA scripts
# -----------------------------------------------------------------------------
# Base URL used by smoke, deep-check, and page-speed scripts.
# Reuses BASE_URL in some runtime code, so keep it aligned with the real app URL.
# BASE_URL="http://localhost:6200"

# Demo credentials used by automation scripts. Replace only if your seed data differs.
E2E_CASHIER_EMAIL="cashier@store.com"
E2E_CASHIER_PASSWORD="Pass1234!"
E2E_OWNER_EMAIL="owner@store.com"
E2E_OWNER_PASSWORD="Pass1234!"
