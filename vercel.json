{
  "buildCommand": "npm run build:vercel",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/eod-summary",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/expire-online-orders",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/dispatch-storefront-notifications",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "app/api/cron/**": { "maxDuration": 60 },
    "app/api/seed-once/**": { "maxDuration": 60 },
    "app/api/import-stock/**": { "maxDuration": 300 },
    "app/api/reset-purchase-data/**": { "maxDuration": 30 },
    "app/api/offline/batch-sync/**": { "maxDuration": 30 },
    "app/api/**": { "maxDuration": 15 }
  }
}
