{
  "name": "tillflow",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/start-local-dev.mjs",
    "dev:prepare": "npm run db:generate:local && npm run db:setup",
    "build": "cross-env NODE_ENV=production next build",
    "build:vercel": "prisma generate --schema=prisma/schema.postgres.prisma && prisma migrate deploy --schema=prisma/schema.postgres.prisma && cross-env NODE_ENV=production next build",
    "db:migrate:create": "prisma migrate dev --schema=prisma/schema.postgres.prisma --create-only",
    "db:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.postgres.prisma",
    "postinstall": "prisma generate --schema=prisma/schema.postgres.prisma",
    "start": "next start",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint app components hooks lib prisma scripts middleware.ts instrumentation.ts next.config.js postcss.config.js tailwind.config.ts vitest.config.ts vitest.setup.ts sentry.client.config.ts sentry.edge.config.ts sentry.server.config.ts --ext .js,.ts,.tsx --no-error-on-unmatched-pattern",
    "test": "vitest run --reporter=dot",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e:critical": "node scripts/critical-path-smoke.js",
    "test:e2e:mobile": "node scripts/mobile-responsiveness-audit.js",
    "test:e2e:smoke": "node scripts/manual-e2e-check.js",
    "test:e2e:deep": "node scripts/manual-e2e-deep-check.js",
    "test:qa:phase3a": "tsx scripts/phase3a-qa.ts",
    "test:qa:phase3b": "tsx scripts/phase3b-qa.ts",
    "test:perf": "node scripts/page-speed-check.js",
    "db:generate:local": "node scripts/generate-local-prisma-client.mjs",
    "db:push": "prisma db push",
    "db:push:local": "prisma db push --accept-data-loss --skip-generate",
    "db:seed": "prisma db seed",
    "db:prepare:ci": "prisma generate --schema=prisma/schema.prisma && prisma db push --schema=prisma/schema.prisma --accept-data-loss && prisma db seed",
    "db:wal": "tsx scripts/enable-wal.ts",
    "db:setup": "npm run db:push:local && npm run db:wal && npm run db:seed",
    "db:reset": "del dev.db 2>nul & npm run db:setup"
  },
  "engines": {
    "node": ">=18 <24"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.43.0",
    "@upstash/redis": "^1.36.2",
    "@vercel/blob": "^2.3.1",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.8.0",
    "chart.js": "^4.5.1",
    "fflate": "^0.8.2",
    "html5-qrcode": "^2.3.8",
    "idb": "^8.0.3",
    "next": "^14.2.35",
    "otplib": "^13.3.0",
    "qrcode": "^1.5.4",
    "qz-tray": "^2.2.5",
    "react": "18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "18.2.0",
    "resend": "^6.9.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/node": "^20.11.30",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.19",
    "better-sqlite3": "^12.6.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.38",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.15.6",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
